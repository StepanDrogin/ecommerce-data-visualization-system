{
  "name": "ecommerce-data-visualization-system",
  "version": "0.1.0",
  "private": true,
  "description": "Research and development of an interactive data visualization system for product and order analytics in e-commerce.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @edvs/shared && npm run build -w @edvs/backend && npm run build -w @edvs/frontend",
    "dev:frontend": "npm run dev -w @edvs/frontend",
    "dev:backend": "npm run start:dev -w @edvs/backend",
    "start:backend": "npm run start -w @edvs/backend",
    "preview:frontend": "npm run preview -w @edvs/frontend",
    "prisma:generate": "npm run prisma:generate -w @edvs/backend",
    "prisma:migrate": "npm run prisma:migrate -w @edvs/backend",
    "prisma:dev:migrate": "npm run prisma:dev:migrate -w @edvs/backend",
    "prisma:seed": "npm run prisma:seed -w @edvs/backend",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "devDependencies": {
    "vitest": "^4.1.5"
  }
}
